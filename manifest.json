{
  "manifest_version": 3,
  "name": "PiP Toggle with P Key",
  "version": "1.0",
  "description": "Press P key to toggle Picture-in-Picture mode on videos",
  "permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
